# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/job-portal

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Cookies
COOKIE_SECURE=false

# Email (Nodemailer - e.g. Gmail app password or Mailtrap/SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM="Job Portal <no-reply@jobportal.com>"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Scraper
SCRAPER_CRON_ENABLED=true
SCRAPER_CRON_SCHEDULE=0 */6 * * *
REMOTIVE_API_URL=https://remotive.com/api/remote-jobs

# Redis (optional cache - leave blank to disable)
REDIS_URL=


CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret


BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=