# Base URL for the backend API. In local dev, Vite's proxy (see vite.config.js)
# forwards /api to the backend, so this can stay relative.
VITE_API_URL=/api

# Used only by vite.config.js's dev-server proxy target
VITE_API_PROXY_TARGET=http://localhost:5000



